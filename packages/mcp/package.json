{
  "name": "event-artillery-mcp",
  "version": "1.0.1",
  "description": "MCP App for generating and sending events to AWS EventBridge from any AsyncAPI spec",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "bin": {
    "event-artillery-mcp": "./dist/main.js"
  },
  "exports": {
    ".": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm run clean && vite build && tsc -p tsconfig.server.json",
    "clean": "rm -rf dist",
    "watch": "vite build --watch",
    "serve": "npx tsx --watch server/main.ts --http",
    "serve:stdio": "npx tsx server/main.ts",
    "dev": "concurrently \"pnpm run watch\" \"pnpm run serve\"",
    "start": "pnpm run build && node dist/main.js --http",
    "start:stdio": "pnpm run build 1>&2 && node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-types": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.app.json --noEmit",
    "prepublishOnly": "pnpm run build && tsc --noEmit"
  },
  "dependencies": {
    "@event-artillery/core": "workspace:*",
    "@modelcontextprotocol/ext-apps": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@xstate/react": "^6.1.0",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.2",
    "lucide-react": "^0.460.0",
    "postcss": "^8.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^4.1.4",
    "xstate": "^5.30.0"
  }
}
